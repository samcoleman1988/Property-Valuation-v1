# Template only — DO NOT put real values in this file.
# This file IS committed to the repo so the required secret keys are
# documented; the actual secrets.toml (with real values) is gitignored
# and never leaves your machine or the Streamlit Cloud dashboard.
#
# Local dev: copy this to .streamlit/secrets.toml and fill in the real
# key, OR just keep using a .env file (both are supported — see
# src/epc.py get_epc_key()).
#
# Streamlit Community Cloud: do NOT create this file in the repo at all.
# Instead paste this same content, with the real key, into
# your app's Settings -> Secrets box on share.streamlit.io.

EPC_API_KEY = "your_base64_encoded_key_here"
